PORT=3001
NODE_ENV=development

# Leave DATABASE_URL blank locally — the backend will use SQLite automatically.
# On Render, this is injected from the Postgres database via render.yaml (fromDatabase).
# DATABASE_URL=

# --- Optional free data-source keys ---
# The app works WITHOUT any of these. GLEIF (ownership) and GDELT (adverse media)
# need no key at all. The keys below just light up extra sources when present.

# UK Companies House — free key: https://developer.company-information.service.gov.uk/
# Enables real natural-person beneficial owners (PSC) for UK companies.
# COMPANIES_HOUSE_API_KEY=

# Adverse-media body check (default on): when the company isn't in a headline, use
# GDELT's CONTEXT sentence and keep the article only if the company + a risk keyword
# share a sentence. Set to false for strict headline-only matching (one fewer API call).
# ADVERSE_BODY_CHECK=true

# SEC EDGAR needs only a User-Agent with a real contact email (no signup).
# Used for US disclosures / financial-distress signals.
# SEC_USER_AGENT=KYB-DueDiligence/1.0 you@example.com

# CourtListener — free token: https://www.courtlistener.com/profile/api-token/
# Enables the US litigation & bankruptcy panel.
# COURTLISTENER_TOKEN=
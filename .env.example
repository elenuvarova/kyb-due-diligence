PORT=3001
NODE_ENV=development

# Leave DATABASE_URL blank locally — the backend will use SQLite automatically.
# DATABASE_URL=

# ==============================================================================
# COOLIFY DEPLOYMENT — paste these into Environment Variables in the Coolify UI
# (Configuration → Environment Variables → Developer view), then Redeploy.
# ==============================================================================
#
# NODE_ENV=production
# PORT=3001
# DATABASE_URL=postgres://postgres:PASSWORD@CONTAINER_NAME:5432/postgres
#   ^ copy "Postgres URL (internal)" from the Coolify Postgres resource page
#   ^ no ?sslmode=require needed — internal Coolify Postgres has no SSL
#
# SEC_USER_AGENT=KYB-DueDiligence/1.0 you@example.com
# COMPANIES_HOUSE_API_KEY=your_key
# COURTLISTENER_TOKEN=your_token
# WIKIDATA_USER_AGENT=KYB-DueDiligence/1.0 (https://your-site; you@example.com)
#
# HTTP Basic Auth gate — protects the whole app (SPA + /api/*) on the public
# internet. Set BOTH to enable; leave either blank to disable. /api/health is
# always exempt so the container HEALTHCHECK keeps passing.
# BASIC_AUTH_USER=your_user
# BASIC_AUTH_PASSWORD=a_long_random_password
#
# Secrets live ONLY in the Coolify env-var UI in production — never in a file in
# the image. The Dockerfile + .dockerignore deliberately keep backend/.env out of
# the build, and the app reads everything from process.env.
# ==============================================================================

# --- Optional free data-source keys (work locally too) ---
# The app works WITHOUT any of these. GLEIF (ownership) and GDELT (adverse media)
# need no key at all. The keys below just light up extra sources when present.

# UK Companies House — free key: https://developer.company-information.service.gov.uk/
# Enables real natural-person beneficial owners (PSC) for UK companies.
# COMPANIES_HOUSE_API_KEY=

# Adverse-media body check (default on): when the company isn't in a headline, use
# GDELT's CONTEXT sentence and keep the article only if the company + a risk keyword
# share a sentence. Set to false for strict headline-only matching (one fewer API call).
# ADVERSE_BODY_CHECK=true

# SEC EDGAR needs only a User-Agent with a real contact email (no signup).
# Used for US disclosures / financial-distress signals.
# SEC_USER_AGENT=KYB-DueDiligence/1.0 you@example.com

# CourtListener — free token: https://www.courtlistener.com/profile/api-token/
# Enables the US litigation & bankruptcy panel.
# COURTLISTENER_TOKEN=

# Wikidata PEP enrichment needs no key — only a descriptive User-Agent with contact info
# (per Wikidata's usage policy). A built-in default is used if this is unset; override it
# with your own contact for production. Flags beneficial owners whose exact name matches a
# Wikidata politician (a lead to verify, never a conclusion).
# WIKIDATA_USER_AGENT=KYB-DueDiligence/1.0 (https://your-site; you@example.com)
